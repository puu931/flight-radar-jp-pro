# Telegram (optional — leave blank to skip)
BOT_TOKEN=
CHAT_ID=

# Discord webhook (optional — leave blank to skip)
DISCORD_WEBHOOK_URL=

# Amadeus Self-Service (https://developers.amadeus.com/)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Travelpayouts / Aviasales (free, affiliate-based — https://www.travelpayouts.com/)
# TOKEN: from your dashboard → Developers → API access
# MARKER: your affiliate marker (4-6 digit number) — appended to booking links
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# SerpAPI Google Flights (optional, https://serpapi.com/)
SERPAPI_KEY=

# Database
# Local dev: keep SQLite. Production: use Postgres (Supabase / Render / etc).
# Both `postgres://...` and `postgresql://...` URLs are accepted; we'll
# route through psycopg3 automatically.
DATABASE_URL=sqlite:///./flights.db

# Source selection: comma-separated. Options: mock, amadeus, travelpayouts, serpapi
FLIGHT_SOURCES=mock

# FX
USD_TO_TWD=32.0
JPY_TO_TWD=0.21
